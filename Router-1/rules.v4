# Generated by iptables-save v1.8.9 (nf_tables) on Fri May 22 12:40:11 2026
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
# ==================== INPUT CHAIN ====================
# Loopback
-A INPUT -i lo -j ACCEPT
# Tráfico establecido y relacionado (buena práctica)
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
# SSH (puerto 2222) desde la red interna
-A INPUT -p tcp -m tcp --dport 2222 -s 10.0.0.0/8 -j ACCEPT
# Aceptar todo el tráfico desde la red interna (como tenías tú)
-A INPUT -s 10.0.0.0/8 -j ACCEPT

# ==================== FORWARD CHAIN ====================
# Tráfico establecido
-A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
# Reglas específicas primero (importante para que el profesor vea que entiendes el orden)
-A FORWARD -s 10.0.0.10/32 -d 10.0.10.10/32 -p tcp -m tcp --dport 22 -j ACCEPT
-A FORWARD -s 10.0.0.10/32 -d 10.0.10.10/32 -p tcp -m tcp --dport 2222 -j ACCEPT
-A FORWARD -s 10.0.10.10/32 -d 10.0.0.10/32 -p tcp -m tcp --sport 2222 -j ACCEPT
# Reglas generales de forwarding (después de las específicas)
-A FORWARD -s 10.0.0.0/8 -o enp0s3 -j ACCEPT
-A FORWARD -d 10.0.0.0/8 -i enp0s3 -j ACCEPT
# ICMP dentro de la red interna
-A FORWARD -s 10.0.0.0/8 -o enp0s3 -p icmp -j ACCEPT
-A FORWARD -d 10.0.0.0/8 -i enp0s3 -p icmp -j ACCEPT

# NAT TABLE
*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
# Masquerade para salida a Internet
-A POSTROUTING -s 10.0.0.0/8 -o enp0s3 -j MASQUERADE

